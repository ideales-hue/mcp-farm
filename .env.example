# MCP Farm — Environment Variable Template
# Copy this to .env and fill in your values. NEVER commit .env to source control.

# ── Atlassian (shared token works for both Jira and Confluence) ───────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@yourorg.com
JIRA_API_TOKEN=ATATT3xFfGF0...

CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_EMAIL=you@yourorg.com
CONFLUENCE_API_TOKEN=ATATT3xFfGF0...

# ── BMC Remedy ────────────────────────────────────────────────────────────────
REMEDY_BASE_URL=https://remedy.yourorg.com
REMEDY_USERNAME=svc_mcp_account
REMEDY_PASSWORD=change_me
REMEDY_PORT=8008

# ── BMC CMDB (usually same server as Remedy) ──────────────────────────────────
CMDB_BASE_URL=https://remedy.yourorg.com
CMDB_USERNAME=svc_mcp_account
CMDB_PASSWORD=change_me
CMDB_PORT=8008

# ── Splunk ────────────────────────────────────────────────────────────────────
SPLUNK_BASE_URL=https://splunk.yourorg.com:8089
SPLUNK_TOKEN=eyJraWQiOi...
# Or use basic auth:
# SPLUNK_USERNAME=admin
# SPLUNK_PASSWORD=change_me

# ── Dynatrace ─────────────────────────────────────────────────────────────────
DYNATRACE_BASE_URL=https://abc12345.live.dynatrace.com
DYNATRACE_API_TOKEN=dt0c01.your-token-here...
